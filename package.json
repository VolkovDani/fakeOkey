{
  "name": "fakeokey",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npx tsx --watch index.ts",
    "prod:client": "cd client && npm run preview",
    "prod:server": "cd server && npx tsx index.ts",
    "prod:client:build": "cd client && npm run build",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "prod": "concurrently \"npm run prod:client\" \"npm run prod:server\"",
    "test": "npm run test -w shared"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
